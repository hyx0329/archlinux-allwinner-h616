# working directory
WORKING_DIR="/tmp/image-build"

# image file name
IMAGE_NAME="test-image.img"

# full image size, in MiB
IMAGE_SIZE=4096

# swapfile size, in MiB. swapfile is used so the partition can be flexible
# swapfile location is hardcoded to /swapfile
SWAP_SIZE=1024

# config to bootstrap the rootfs
# see resources folder for other predefined configurations
PACSTRAP_PACMAN_CONFIG=resources/arch-stage0-eu-pacman.conf

# partition setup, for MBR scheme
MBR_PARTITION_SETUP=(
    # Replace btrfs with ext4 if you want ext4:
    # primary:32768s:100%:ext4:ROOTFS:/
    primary:32768s:100%:btrfs:ROOTFS:/
)

# packages to be installed when bootstrapping
PACSTRAP_PACKAGES=(
    base
    archlinuxarm-keyring
    uboot-tools # for automatic init ramdisk generation
    sudo
    vim
    nano
    openssh

    linux-firmware-atheros
    #linux-firmware-broadcom
    linux-firmware-cirrus
    #linux-firmware-intel
    linux-firmware-mediatek
    linux-firmware-other
    linux-firmware-realtek

    wireless-regdb
    #iwd
    networkmanager
    bluez
    bluez-utils

    tmux
    htop
    btop
    bat
    less
    git
    usbutils
    aria2
    #7zip

    pacman-contrib

    # Comment this if you on ext4
    btrfs-progs
    #base-devel
)

INSTALL_EXTRA_PACKAGES=(
    # Linux kernel
    ../prebuilts/linux-sunxi64-armbian-6.12.23.current1-1-aarch64.pkg.tar.xz
    #../prebuilts/linux-sunxi64-armbian-headers-6.12.23.current1-1-aarch64.pkg.tar.xz
)

INSTALL_STATIC_FILES=(
    # generate initrd for u-boot
    ../distro-scripts/make-initrd.hook:etc/initcpio/post/80-make-initrd.hook:755

    # naive auto cache clean, just to prevent cache taking over the whole disk
    ../distro-scripts/paccache-clean.hook:etc/pacman.d/hooks/paccache-clean.hook:644

    # RTL8723DS firmware
    ../linux-firmware/rtl_bt/rtl8723ds_fw.bin:usr/lib/firmware/rtl_bt/rtl8723ds_fw.bin:644
    ../linux-firmware/rtl_bt/rtl8723ds_config.bin:usr/lib/firmware/rtl_bt/rtl8723ds_config.bin:644

    ## UWE5622 firmware, helper scripts, and userspace driver
    ## Avoid loading uwe5622 driver on platforms without it
    #../distro-scripts/modprobe.d/uwe5622.conf:etc/modprobe.d/uwe5622.conf.example:644
    #../distro-scripts/modules-load.d/uwe5622.conf:etc/modules-load.d/uwe5622.conf.example:644
    ## The userspace driver for bluetooth part
    #../prebuilts/hciattach-opi-0.1.0-1-aarch64.pkg.tar.xz
    uwe5622/wcnmodem.bin:usr/lib/firmware/wcnmodem.bin:link
    uwe5622/wifi_2355b001_1ant.ini:usr/lib/firmware/wifi_2355b001_1ant.ini:link
    ../linux-firmware/uwe5622/wcnmodem-38222.bin:usr/lib/firmware/uwe5622/wcnmodem-38222.bin
    ../linux-firmware/uwe5622/wcnmodem.bin:usr/lib/firmware/uwe5622/wcnmodem.bin
    ../linux-firmware/uwe5622/wifi_2355b001_1ant.ini:usr/lib/firmware/uwe5622/wifi_2355b001_1ant.ini

    # uboot defaults to search in dtb folder, link it
    dtb-linux-sunxi64-armbian:boot/dtb:link
)

# path to the u-boot file
UBOOT_BINARY=../prebuilts/orangepi_zero_2w-u-boot-sunxi-with-spl.bin

# sector count, sector size 512Byte
UBOOT_OFFSET=16
UBOOT_ARCH=arm64
BOOT_SCRIPT_TEMPLATE=resources/boot.cmd.h616-template
BOOT_ENV_TEMPLATE=resources/bootEnv.txt.h616-template

# Privileged user, will not create if unset
NEW_PRIV_USER=niko
NEW_PRIV_USER_PASS=niko
# New privileged user is added to group wheel automatically nevertheless
NEW_PRIV_USER_GROUPS=(adm)
