source settings.env

INSTALL_STATIC_FILES=(
    ../distro-scripts/paccache-clean.hook:etc/pacman.d/hooks/paccache-clean.hook:644
    ../distro-scripts/make-initrd.hook:etc/initcpio/post/80-make-initrd.hook:755
    ../linux-firmware/rtl_bt/rtl8723ds_fw.bin:usr/lib/firmware/rtl_bt/rtl8723ds_fw.bin:644
    ../linux-firmware/rtl_bt/rtl8723ds_config.bin:usr/lib/firmware/rtl_bt/rtl8723ds_config.bin:644

    # uboot defaults to search in dtb folder, link it
    dtb-linux-sunxi64-armbian:boot/dtb:link
)

# path to the u-boot file
UBOOT_BINARY=../prebuilts/mangopi_mq_quad-u-boot-sunxi-with-spl.bin
