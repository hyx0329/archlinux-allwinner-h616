# linux with armbian patches
# search for "CHANGEME:" when porting

# CHANGEME: Armbian patch config, kernel version, etc.
_kernelversion=6.12.58
# MUST change accordingly
_armbian_commit="ce584a7b147e067c959c95dda88ffd01181c1d3e"
_armbian_patchset=sunxi-${_kernelversion%.*}
_patch_arch=arm64
_patch_platform=allwinner
_patch_dtbmake_prefix='dtb-$(CONFIG_ARCH_SUNXI) += '
_kernel_config="linux-sunxi64-current.config" # kernel config from armbian

# CHANGEME: the package name and version
pkgbase=linux-sunxi64-armbian
pkgver=${_kernelversion}.current1
# CHANGEME: if you are working on other architectures, like riscv
arch=(aarch64)

pkgrel=1
pkgdesc='Linux for Allwinner H616/H618, and possibly other sunxi64 platforms, based on Armbian patches'
url='https://github.com/torvalds/linux'
license=(GPL-2.0-only)
makedepends=(
  bc
  cpio
  gettext
  libelf
  pahole
  perl
  python
  tar
  xz

  # this only required with some platforms due to broken scripts
  # rockchip64 don't need this though
  uboot-tools

  # for lsdiff used when applying patches
  patchutils

  # # Who want doc?
  # # htmldocs
  # graphviz
  # imagemagick
  # python-sphinx
  # python-yaml
  # texlive-latexextra
)
options=(
  !debug
  !strip
)

# Linux source
# Using tarball
_srcname=linux-${_kernelversion}
_srcball="https://cdn.kernel.org/pub/linux/kernel/v${_kernelversion%%.*}.x/${_srcname}.tar.xz"

source=(
  # armbian source
  "armbian-build::git+https://github.com/armbian/build.git#commit=${_armbian_commit}"

  apply-uwe5622.sh

  "${_srcball}" # kernel source using tarball

  # device trees, overwrite the old ones directly
  sun50i-h616-mangopi-mq-quad.dts
  sun50i-h618-orangepi-zero2w.dts
  0000-uwe5622-set-mac-through-eth_hw_addr_set.patch
)

